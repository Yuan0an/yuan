{
  "functions": {
    "**/*.php": {
      "runtime": "vercel-php@0.7.1"
    }
  },
  "routes": [
    {
      "src": "/assets/(.*)",
      "dest": "/assets/$1"
    },
    {
      "src": "/auth/(.*)",
      "dest": "/auth/$1"
    },
    {
      "src": "/form/(.*)",
      "dest": "/form/$1"
    },
    {
      "src": "/pages/(.*)",
      "dest": "/pages/$1"
    },
    {
      "src": "/uploader/(.*)",
      "dest": "/uploader/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/index.php"
    }
  ]
}